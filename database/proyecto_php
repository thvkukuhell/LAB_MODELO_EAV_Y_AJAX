-- === VENDEDOR (rol_id = 2) ===
-- Categorías: listar + ver
-- Productos:  listar + ver
-- Ventas:     crear + listar
-- Clientes:   crear + editar + eliminar + listar + ver
-- NO: eliminar_venta, editar_venta
INSERT INTO roles_permisos (rol_id, permiso_id)
SELECT 2, id FROM permisos
WHERE clave_acceso IN (
    'listar_categoria', 'ver_categoria',
    'listar_producto',  'ver_producto',
    'crear_venta',      'listar_venta', 'ver_venta',
    'crear_cliente',    'editar_cliente', 'eliminar_cliente',
    'listar_cliente',   'ver_cliente'
);

-- === ALMACENERO (rol_id = 3) ===
-- Categorías: acceso total
-- Productos:  acceso total
-- NO ventas, NO clientes
INSERT INTO roles_permisos (rol_id, permiso_id)
